{
  "version": 2,
  "builds": [
    {
      "src": "api/soc_api.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/soc_api.py"
    },
    {
      "src": "/soc-dashboard.html",
      "dest": "/public/soc-dashboard.html"
    },
    {
      "src": "/",
      "dest": "/public/soc-dashboard.html"
    },
    {
      "src": "/tutorial-viewer.html",
      "dest": "/public/tutorial-viewer.html"
    },
    {
      "src": "/(.*\\.md)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
