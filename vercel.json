{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/data/(.*)",
      "dest": "/public/data/$1"
    },
    {
      "src": "/(.*\\.(js|css|json|md|html|png|jpg|svg|ico|webp))",
      "dest": "/public/$1"
    },
    {
      "src": "/",
      "dest": "/public/soc-dashboard.html"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
